OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-10-01-preview
NGROK_AUTH_TOKEN=YOUR_NGROK_AUTH_TOKEN_HERE

# ── Production SQL Server ─────────────────────────────────────────────────────
# Fill these in on the production machine (SRVDNZ).
# Windows Authentication (Trusted_Connection=yes) is used — no password needed.
PROD_SERVER=SRVDNZ
PROD_DB_NAME=YOUR_DATABASE_NAME_HERE
